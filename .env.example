# Resend API key for the /api/contact form endpoint.
# Get it from https://resend.com (Account → API Keys), then:
#   - local:  copy this file to .env and paste your key below
#   - Vercel: add RESEND_API_KEY under Project Settings → Environment Variables
#             (scope to Production AND Preview)
RESEND_API_KEY=re_your_key_here

# Sanity (the blog backend — project "adambarnes-blog").
# These are public identifiers, not secrets; src/lib/sanity.ts hard-codes them
# as defaults, so setting these is optional (only needed to point at a different
# project/dataset).
SANITY_PROJECT_ID=03e66gen
SANITY_DATASET=production
