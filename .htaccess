Options -Indexes

# Block access to version control and sensitive files
<FilesMatch "(^\.git|^\.gitignore|^\.env|^\.DS_Store|TECHNICAL-REFERENCE\.md)">
  Require all denied
</FilesMatch>

# Compress text-based assets when Apache's compression module is available.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache static assets aggressively, while keeping HTML easy to update.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresDefault "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(?:avif|gif|ico|jpe?g|png|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html?)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

RewriteEngine On

# ── HTTPS ──────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── www canonical ──────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^adambarnes\.biz [NC]
RewriteRule ^ https://www.adambarnes.biz%{REQUEST_URI} [R=301,L]

# ── Old site redirects (301 permanent) ─────────────────────────
RewriteRule ^index\.html$   /               [R=301,L]
RewriteRule ^team/?$        /about.html      [R=301,L]
RewriteRule ^showcase/?$    /web-design.html [R=301,L]
RewriteRule ^contact/?$     /contact.html    [R=301,L]

# ── Common old WordPress paths ─────────────────────────────────
RewriteRule ^portfolio/?$   /web-design.html [R=301,L]
RewriteRule ^services/?$    /web-design.html [R=301,L]
RewriteRule ^about/?$       /about.html      [R=301,L]
RewriteRule ^photography/?$ /photography.html [R=301,L]
RewriteRule ^blog/?.*$      /               [R=301,L]
