---
import Base from '../layouts/Base.astro';
---
<Base
  title="adambarnesphotos.co.uk | Image-Heavy Photography Portfolio Case Study | Adam Barnes"
  description="How my photography portfolio handles a full-screen video homepage and hundreds of high-resolution images while still loading fast, built with Next.js and Sanity."
  canonical="https://www.adambarnes.biz/case-study-adambarnesphotos.html"
  ogImage="https://www.adambarnes.biz/assets/og-image.jpg"
  ogType="article"
  bodyClass="page-webdesign"
  active="web-design"
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline>
{
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": "adambarnesphotos.co.uk",
    "url": "https://www.adambarnesphotos.co.uk",
    "creator": {
      "@type": "Person",
      "name": "Adam Barnes",
      "url": "https://www.adambarnes.biz"
    },
    "description": "An image-heavy photography portfolio with a full-screen video homepage and hundreds of high-resolution photographs, built with Next.js and Sanity for instant performance.",
    "keywords": [
      "Next.js",
      "Sanity",
      "Headless CMS",
      "Performance",
      "Image Optimisation",
      "Photography Portfolio",
      "Web Design"
    ]
  }
  </script>
  <script type="application/ld+json" is:inline>
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.adambarnes.biz/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Web Design",
        "item": "https://www.adambarnes.biz/web-design.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "adambarnesphotos.co.uk",
        "item": "https://www.adambarnes.biz/case-study-adambarnesphotos.html"
      }
    ]
  }
  </script>
  <script type="application/ld+json" is:inline>
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "adambarnesphotos.co.uk — Image-Heavy Photography Portfolio Case Study",
    "description": "How my photography portfolio handles a full-screen video homepage and hundreds of high-resolution images while still loading fast — built with Next.js and Sanity.",
    "about": {
        "@type": "Organization",
        "name": "adambarnesphotos.co.uk",
        "url": "https://www.adambarnesphotos.co.uk"
    },
    "url": "https://www.adambarnes.biz/case-study-adambarnesphotos.html",
    "author": {
        "@type": "Person",
        "name": "Adam Barnes",
        "url": "https://www.adambarnes.biz"
    },
    "publisher": {
        "@type": "Person",
        "name": "Adam Barnes",
        "url": "https://www.adambarnes.biz"
    },
    "datePublished": "2026-06-11",
    "dateModified": "2026-06-11"
}
  </script>
  </Fragment>

<main>

    <!-- Page header -->
    <header class="section-header webdesign-header cs-header">
      <div class="cs-header-text">
        <h1 class="section-title">
          <span>Image</span>
          <span class="accent">Heavy</span>
          <span class="by-line">by Adam</span>
        </h1>
        <p class="section-intro">
          <span class="intro-lead">Image-heavy doesn't have to mean slow.</span>
          My photography portfolio is also my hardest brief: a full-screen video homepage, hundreds of high-resolution photographs, and it still has to load instantly. Built with Next.js and Sanity.
        </p>
      </div>
      <div class="cs-header-logo cs-header-logo--wide" aria-hidden="true">
        <img src="assets/logo.svg" alt="" class="cs-header-logo-img">
      </div>
    </header>

    <!-- Case study body -->
    <section class="cs-body reveal" aria-label="Case study detail">
      <div class="cs-body-inner">

        <!-- Meta strip -->
        <div class="cs-meta">
          <div class="cs-meta-item">
            <span class="cs-meta-label">Project</span>
            <span class="cs-meta-value">adambarnesphotos.co.uk</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Live site</span>
            <span class="cs-meta-value"><a href="https://www.adambarnesphotos.co.uk" target="_blank" rel="noopener">adambarnesphotos.co.uk</a></span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Built with</span>
            <span class="cs-meta-value">Next.js &middot; Sanity &middot; Vercel</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Optimised for</span>
            <span class="cs-meta-value">Performance &middot; Image delivery</span>
          </div>
        </div>

        <!-- Narrative -->
        <div class="cs-copy">
          <div class="cs-copy-col">

            <h2 class="cs-copy-heading">The brief</h2>
            <p>My photography portfolio is also my hardest brief. A full-screen video homepage, hundreds of high-resolution photographs across eleven portfolio categories, and it still has to load instantly.</p>
            <p>Most page builders struggle the moment a site gets seriously visual. Every image adds weight, every plugin adds drag, and before long a beautiful portfolio takes five seconds to appear.</p>

            <h2 class="cs-copy-heading">The approach</h2>
            <p>So when I built it, I treated it like a client project with an unreasonable brief and no patience for loading spinners.</p>
            <p>The answer was Next.js and Sanity. Next.js handles the front end and keeps everything fast. Sanity provides a structured backend, so every photograph, caption and category lives as proper content rather than being bolted into pages. Images are served through Sanity's CDN, sized and optimised automatically for whatever screen they land on.</p>

          </div>
          <div class="cs-copy-col">

            <h2 class="cs-copy-heading">The result</h2>
            <p>Google Lighthouse scores the site 100 for Performance. Not 90-something. 100, with a full-screen video above the fold and a site carrying more imagery than almost any business website would ever need. It scores 100 for SEO and Best Practices too.</p>
            <p>It works in the other direction as well. Behind the scenes, publishing a new shoot takes minutes, with none of the wrestling a traditional page builder demands.</p>

            <h2 class="cs-copy-heading">Is this for you?</h2>
            <p>If your site is image-heavy, content-heavy, or just needs to be properly quick, this is the approach I'd recommend. See it running at <a href="https://www.adambarnesphotos.co.uk" target="_blank" rel="noopener">adambarnesphotos.co.uk</a>.</p>
            <p>If you think your project might benefit from the same approach, <a href="contact.html">get in touch</a>.</p>

          </div>
        </div>

        <!-- Technical highlights -->
        <div class="cs-tech-strip reveal">
          <div class="cs-tech-item">
            <span class="cs-tech-label">Stack</span>
            <span class="cs-tech-value">Next.js &middot; React</span>
          </div>
          <div class="cs-tech-item">
            <span class="cs-tech-label">CMS</span>
            <span class="cs-tech-value">Sanity (headless)</span>
          </div>
          <div class="cs-tech-item">
            <span class="cs-tech-label">Images</span>
            <span class="cs-tech-value">Sanity CDN &middot; auto-optimised</span>
          </div>
          <div class="cs-tech-item">
            <span class="cs-tech-label">Hosting</span>
            <span class="cs-tech-value">Vercel</span>
          </div>
          <div class="cs-tech-item">
            <span class="cs-tech-label">Lighthouse</span>
            <span class="cs-tech-value">100 &middot; Performance, SEO &amp; Best Practices</span>
          </div>
          <div class="cs-tech-item">
            <span class="cs-tech-label">Portfolio</span>
            <span class="cs-tech-value">Eleven categories &middot; hundreds of images</span>
          </div>
        </div>

      </div>
    </section>

    <!-- Screenshots -->
    <section class="cs-screenshots reveal" aria-label="Project screenshots">
      <figure class="cs-screenshot">
        <img src="assets/images/adambarnesphotos-home-page.jpg" alt="adambarnesphotos.co.uk, full-screen video homepage" class="cs-screenshot-img" loading="lazy">
        <figcaption>Homepage, a full-screen video above the fold</figcaption>
      </figure>
      <figure class="cs-screenshot">
        <img src="assets/images/adambarnesphotos-portfolio-page.jpg" alt="adambarnesphotos.co.uk, portfolio page" class="cs-screenshot-img" loading="lazy">
        <figcaption>Portfolio, hundreds of images across eleven categories</figcaption>
      </figure>
    </section>

    <!-- Back link + CTA -->
    <div class="cs-footer-nav reveal">
      <a href="web-design.html" class="cs-back-link">&larr; Back to Web Design</a>
      <a href="contact.html" class="btn">Start a project</a>
    </div>

  </main>
</Base>
