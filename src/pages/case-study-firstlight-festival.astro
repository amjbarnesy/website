          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/5Firstlight.webp" alt="First Light Festival" width="1200" height="580">
              <div class="photo-overlay"><span class="photo-caption">First Light Festival</span></div>
          </div>

