          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/lotty-grey.webp" alt="Lotty Grey - First Light Festival" width="800" height="1200">
              <div class="photo-overlay"><span class="photo-caption">Lotty Grey - First Light Festival</span></div>
          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/14Firstlight.webp" alt="First Light Festival" width="1200" height="800">
              <div class="photo-overlay"><span class="photo-caption">First Light Festival</span></div>
          </div>

        </div>

      </div>
    </section>

    <!-- Back link + CTA -->
    <div class="cs-footer-nav reveal">
      <a href="clients.html" class="cs-back-link">← Back to Clients</a>
      <a href="contact.html" class="btn">Start a project</a>
    </div>

  </main>
</Base>
