              <div class="photo-overlay"><span class="photo-caption">First Light Festival</span></div>
          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/8Firstlight.webp" alt="First Light Festival" width="1200" height="800">
              <div class="photo-overlay"><span class="photo-caption">First Light Festival</span></div>
          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/9Firstlight.webp" alt="First Light Festival" width="1200" height="649">
              <div class="photo-overlay"><span class="photo-caption">First Light Festival</span></div>
          </div>

          <div class="photo-item">
              <img src="assets/casestudies/firstlight/10Firstlight.webp" alt="Tom McRae - First Light Festival" width="800" height="1200">
              <div class="photo-overlay"><span class="photo-caption">Tom McRae - First Light Festival</span></div>
