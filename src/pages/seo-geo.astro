---
import Base from '../layouts/Base.astro';
// Inlined (not <img>) so the site's dark-mode toggle can reach the SVG's text.
import seoVsGeoDiagram from '../assets/seo-vs-geo.svg?raw';
---
<Base
  title="SEO & GEO — Adam Barnes | Getting Found on Google and by AI, Norfolk & Suffolk"
  description="SEO and generative engine optimisation (GEO) for businesses that want to be found on Google and by AI. Built into the site from day one, not bolted on. 25 years of experience, based in Norfolk."
  canonical="https://www.adambarnes.biz/seo-geo.html"
  ogImage="https://www.adambarnes.biz/assets/og-image.jpg"
  bodyClass="page-webdesign"
  active="seo-geo"
  breadcrumbLabel="SEO & GEO"
>
  <Fragment slot="head">
  <script type="application/ld+json" is:inline>
{
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://www.adambarnes.biz/seo-geo.html#service",
    "name": "SEO & GEO by Adam Barnes",
    "provider": {
      "@type": "Person",
      "@id": "https://www.adambarnes.biz/#person",
      "name": "Adam Barnes",
      "url": "https://www.adambarnes.biz"
    },
    "serviceType": "SEO and Generative Engine Optimisation",
    "description": "SEO and generative engine optimisation (GEO) for businesses that want to be found on Google and by AI. Clean semantic HTML, structured data and page speed built into the site from day one, not bolted on afterwards. 25 years of experience.",
    "areaServed": [
      "Norfolk",
      "Suffolk",
      "East Anglia",
      "United Kingdom"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "SEO & GEO Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Search Engine Optimisation (SEO)",
            "description": "Getting found by search engines like Google through clean semantic HTML, structured data, page speed and content that answers real questions."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Generative Engine Optimisation (GEO)",
            "description": "Getting found by AI tools like ChatGPT, Claude and Perplexity, so your business is quoted in the single answer they write, not just crawled."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "SEO & GEO Audit",
            "description": "A plain assessment of where a site stands, what is holding it back, and what is worth fixing first, seen the way Google and an AI would."
          }
        }
      ]
    },
    "url": "https://www.adambarnes.biz/seo-geo.html"
  }
  </script>
  <script type="application/ld+json" is:inline>
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://www.adambarnes.biz/seo-geo.html#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What's the difference between SEO and GEO?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SEO gets you found by search engines like Google. GEO gets you found by AI tools like ChatGPT and Perplexity, which write a single answer instead of listing links. Done properly, the same work helps with both."
        }
      },
      {
        "@type": "Question",
        "name": "Does my business actually need GEO?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your customers ask AI for recommendations, and more of them do every month, then yes. GEO is how you end up in that answer instead of watching a competitor take it."
        }
      },
      {
        "@type": "Question",
        "name": "Can you improve a site you didn't build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Usually, yes. I start with an audit, tell you what's holding the site back, and fix what's worth fixing. Sometimes that's small tweaks. Sometimes it's a rebuild. I'll be straight with you either way."
        }
      },
      {
        "@type": "Question",
        "name": "How long until it works?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SEO is a slow burn, weeks to months rather than days. GEO can move faster, because far fewer businesses are doing it yet. Either way I'd rather set honest expectations than promise page one by Friday."
        }
      }
    ]
  }
  </script>
  </Fragment>

<main>

    <!-- Page header / hero -->
    <header class="section-header webdesign-header">
      <h1 class="section-title">
        <span>Inspired</span>
        <span class="accent">Search</span>
        <span class="by-line">by Adam</span>
      </h1>
      <h2 class="intro-lead">SEO and GEO. Found by Google, and by AI.</h2>
      <p class="section-intro">More and more people skip the results page and just ask ChatGPT, Claude or Perplexity. They get one answer back, no links to scan. If your business isn't in it, you're not in the conversation.</p>
      <p class="section-intro">I build sites that win in both places, the old way and the new. Nothing bolted on afterwards.</p>
    </header>

    <!-- Body -->
    <section class="cs-body reveal" aria-label="SEO and GEO explained">
      <div class="cs-body-inner">

        <!-- Facts strip -->
        <div class="cs-meta">
          <div class="cs-meta-item">
            <span class="cs-meta-label">Service</span>
            <span class="cs-meta-value">SEO &amp; Generative Engine Optimisation</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Area served</span>
            <span class="cs-meta-value">Norfolk · Suffolk · East Anglia</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Experience</span>
            <span class="cs-meta-value">25 years</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Start with</span>
            <span class="cs-meta-value">A site audit</span>
          </div>
        </div>

        <!-- The difference, in plain terms -->
        <div class="cs-copy">
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">SEO — found by search engines</h2>
            <p>SEO is getting found by search engines. Google reads your site, works out what it's about, and decides where you rank. This is well-trodden ground, and I've been doing it for 25 years.</p>
          </div>
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">GEO — found by AI</h2>
            <p>GEO is getting found by AI. Generative engines don't rank a list, they write an answer. To be in that answer, an AI has to be able to read your site cleanly, understand it, and trust it enough to quote it. Most sites fail on the first step.</p>
          </div>
        </div>
        <blockquote class="cs-quote">
          <p>The good news is the two pull in the same direction. A site built properly for AI is usually a better site for Google too. Fast, clean, well structured, easy to understand. Do it right and you don't choose between them. You get both.</p>
        </blockquote>

        <!-- SEO vs GEO explainer. PLACEHOLDER — Adam to supply a simple, on-brand
             diagram: Google returns a list of links, AI returns one written answer.
             Ideally an accessible inline SVG with <title> and <desc>. -->
        <figure class="cs-figure" style="margin:2.5rem 0 0;">
          <Fragment set:html={seoVsGeoDiagram} />
          <figcaption>Two ways of being found: a list of links, or the single answer</figcaption>
        </figure>

        <!-- Why it's built in, not bolted on -->
        <div class="cs-copy" style="margin-top:2.5rem;">
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">Built in, not bolted on</h2>
            <p>Most people treat search as a thing you bolt on after the site is finished. A plugin, a checklist, a monthly retainer with a spreadsheet attached.</p>
            <p>I don't work that way. The way a site is built decides whether it can be found at all. Clean semantic HTML, structured data baked in from the start, pages that load in under a second, content that actually answers the questions people ask. You can't sprinkle that on at the end. It's the foundation.</p>
          </div>
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">Design and search, together</h2>
            <p>That's the whole point of doing design and search together. The site and its visibility come from the same place, joined up from day one.</p>
          </div>
        </div>

        <!-- If you don't like football -->
        <blockquote class="cs-quote">
          <p>I wrote a piece explaining all of this using the World Cup, for anyone who'd rather not sit through the jargon. Same idea, fewer acronyms.</p>
          <a href="/blog/dont-like-football.html">Read it in Thinking →</a>
        </blockquote>

        <!-- How I do it -->
        <div class="cs-copy" style="margin-top:2.5rem;">
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">How I do it</h2>
            <p>No secret sauce. Just the work done properly.</p>
          </div>
          <div class="cs-copy-col">
            <ul class="cs-list">
              <li>Clean, semantic HTML that AI and Google can both read without a fight</li>
              <li>Structured data and schema so machines understand what your pages actually mean</li>
              <li>Page speed treated as a feature, not an afterthought</li>
              <li>Content written to answer real questions, not to please a keyword tool</li>
              <li>Internal linking and structure that helps you get quoted, not just crawled</li>
              <li>A site you can measure, so you can see what's working</li>
            </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- Proof -->
    <section class="cs-body reveal" aria-label="Proof">
      <div class="cs-body-inner">
        <h2 class="cs-copy-heading">Proof</h2>
        <p class="section-intro" style="margin-top:0.5rem;">I don't just talk about this. I build it.</p>
      </div>
    </section>

    <section class="clients-grid" aria-label="Proof of work">

      <!-- This site -->
      <article class="client-card reveal feature">
        <div class="client-avatar-row">
          <div class="client-logo-circle" aria-hidden="true"><img src="assets/logo.svg" alt="Adam Barnes logo"></div>
        </div>
        <h3 class="client-name"><a href="case-study-adambarnes-biz.html">This site</a></h3>
        <p class="client-desc">Hand-coded, no CMS, no framework. Structured data from day one and pages that load instantly. It's the clearest demonstration I have that a site built for search visibility genuinely outperforms a templated one. You're reading the case study.</p>
        <ul class="client-tags" aria-label="What was involved">
          <li>Semantic HTML</li>
          <li>Structured Data</li>
          <li>Performance</li>
          <li>AI-Ready</li>
        </ul>
        <a href="case-study-adambarnes-biz.html" class="cs-card-link">View case study →</a>
      </article>

      <!-- Tom Appleton -->
      <article class="client-card reveal">
        <div class="client-avatar-row">
          <div class="client-logo-circle" aria-hidden="true"><img src="assets/logos/tom-appleton.webp" alt="Tom Appleton Arts logo"></div>
        </div>
        <h3 class="client-name"><a href="case-study-tom-appleton.html">Tom Appleton Arts</a></h3>
        <p class="client-desc">A London artist who needed to be found. Service and FAQ schema, a properly configured setup, internal links that make sense, and a site that reads cleanly to both Google and AI.</p>
        <ul class="client-tags" aria-label="What was involved">
          <li>Schema</li>
          <li>SEO</li>
          <li>GEO</li>
        </ul>
        <a href="case-study-tom-appleton.html" class="cs-card-link">View case study →</a>
      </article>

      <!-- Gardner Denley -->
      <article class="client-card reveal">
        <div class="client-avatar-row">
          <div class="client-logo-circle" aria-hidden="true"><img src="assets/logos/gardnerdenley.svg" alt="Gardner Denley logo"></div>
        </div>
        <h3 class="client-name"><a href="case-study-gardner-denley.html">Gardner Denley</a></h3>
        <p class="client-desc">A full SEO and GEO audit for this Cambridge property consultancy, framed as a forward-looking opportunity rather than a list of faults. A clear picture of where they stood and where the gains were.</p>
        <ul class="client-tags" aria-label="What was involved">
          <li>Audit</li>
          <li>SEO</li>
          <li>GEO</li>
        </ul>
        <a href="case-study-gardner-denley.html" class="cs-card-link">View case study →</a>
      </article>

    </section>

    <!-- Proof screenshot. PLACEHOLDER — Adam to supply a real one: a perfect
         Lighthouse / PageSpeed score for adambarnes.biz, or an AI tool citing the site. -->
    <figure class="cs-figure reveal" aria-label="Performance proof">
      <img src="assets/images/seo-geo-lighthouse.webp" alt="Lighthouse report showing top scores for adambarnes.biz across performance, accessibility, best practices and SEO" width="2005" height="1708" loading="lazy">
      <figcaption>The proof is measurable</figcaption>
    </figure>

    <!-- FAQ -->
    <section class="faq-body reveal" aria-label="SEO and GEO questions">
      <div class="faq-inner">

        <div class="faq-col">

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">What's the difference between SEO and GEO?</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer" role="region">
              <div class="faq-answer-inner">
                <p>SEO gets you found by search engines like Google. GEO gets you found by AI tools like ChatGPT and Perplexity, which write a single answer instead of listing links. Done properly, the same work helps with both.</p>
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">Does my business actually need GEO?</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer" role="region">
              <div class="faq-answer-inner">
                <p>If your customers ask AI for recommendations, and more of them do every month, then yes. GEO is how you end up in that answer instead of watching a competitor take it.</p>
              </div>
            </div>
          </div>

        </div><!-- /faq-col -->
        <div class="faq-col">

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">Can you improve a site you didn't build?</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer" role="region">
              <div class="faq-answer-inner">
                <p>Usually, yes. I start with an audit, tell you what's holding the site back, and fix what's worth fixing. Sometimes that's small tweaks. Sometimes it's a rebuild. I'll be straight with you either way.</p>
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">How long until it works?</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer" role="region">
              <div class="faq-answer-inner">
                <p>SEO is a slow burn, weeks to months rather than days. GEO can move faster, because far fewer businesses are doing it yet. Either way I'd rather set honest expectations than promise page one by Friday.</p>
              </div>
            </div>
          </div>

        </div><!-- /faq-col -->

      </div>
    </section>

    <!-- Where to start (last bordered section — drop its bottom border so the
         CTA card below caps the container cleanly, no stray line) -->
    <section class="cs-body reveal" aria-label="Where to start" style="border-bottom:none;">
      <div class="cs-body-inner">
        <div class="cs-copy">
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">Where to start</h2>
            <p>The easiest first step is an audit. I look at your site the way Google and an AI would, and tell you plainly where you stand, what's holding you back, and what's worth fixing first. No obligation to do the work with me afterwards, though most people do.</p>
          </div>
          <div class="cs-copy-col">
            <h2 class="cs-copy-heading">What happens next</h2>
            <p>From there it's either a set of fixes, a rebuild, or an ongoing hand on the tiller. Whatever fits.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA — same pattern as the Clients page CTA card, on this page's orange accent -->
    <section class="clients-grid" style="grid-template-columns:1fr;" aria-label="Get in touch">
      <article class="client-card client-card--cta client-card--cta-wide reveal" style="border:none; margin:0;">
        <p class="client-cta-text" style="border-top:none; padding-top:0;">Want to be found?</p>
        <p class="client-cta-support">Let's talk about where you are and where you could be.</p>
        <a href="contact.html" class="btn-cta" style="margin-top: 1.5rem;">Get in touch</a>
      </article>
    </section>

  </main>

  <button class="back-to-top back-to-top--webdesign" id="back-to-top" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
</Base>
