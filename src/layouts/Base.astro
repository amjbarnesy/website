---
/**
 * Shared site shell — ported 1:1 from the hand-written HTML pages.
 * Per-page bits come in as props; per-page <head> extras (JSON-LD, hero
 * preloads) go in the named "head" slot; page content goes in the default slot.
 */
export interface Props {
  title: string;
  description: string;
  canonical: string;            // full URL, e.g. https://www.adambarnes.biz/about.html
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;             // full URL
  ogType?: string;
  bodyClass?: string;           // e.g. "page-home"
  active?: string;              // nav highlight key, e.g. "web-design"
  navClass?: string;            // optional extra class on <nav> (e.g. nav--on-dark)
  cssVersion?: string;          // cache-bust token for main.css
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://www.adambarnes.biz/assets/og-image.jpg',
  ogType = 'website',
  bodyClass = '',
  active = '',
  navClass = '',
  cssVersion = '20260615b',
} = Astro.props;

// "Thinking" is the blog (/blog.html) — shown site-wide; active key "thinking".
const navLinks = [
  { href: '/web-design.html', label: 'Web Design', key: 'web-design' },
  { href: '/photography.html', label: 'Photography', key: 'photography' },
  { href: '/clients.html', label: 'Clients', key: 'clients' },
  { href: '/about.html', label: 'About', key: 'about' },
  { href: '/faq.html', label: 'FAQ', key: 'faq' },
  { href: '/blog.html', label: 'Thinking', key: 'thinking' },
  { href: '/contact.html', label: 'Contact', key: 'contact' },
];

const menuLinks = [
  { href: '/', label: 'Home', page: 'home' },
  { href: '/web-design.html', label: 'Web Design', page: 'web-design' },
  { href: '/photography.html', label: 'Photography', page: 'photography' },
  { href: '/clients.html', label: 'Clients', page: 'clients' },
  { href: '/about.html', label: 'About', page: 'about' },
  { href: '/faq.html', label: 'FAQ', page: 'faq' },
  { href: '/blog.html', label: 'Thinking', page: 'thinking' },
  { href: '/contact.html', label: 'Contact', page: 'contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Adam Barnes" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Per-page <head> extras: JSON-LD, hero image preloads, etc. -->
  <slot name="head" />

  <link rel="preload" href="/assets/fonts/jost-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/assets/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/css/fonts.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="/css/fonts.css" /></noscript>
  <link rel="stylesheet" href={`/css/main.css?v=${cssVersion}`} />
  <link rel="icon" href="/assets/favicon.svg?v=2" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/icon-192.png?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-icon.png" />
  <script is:inline>!function(){var s=localStorage.getItem('theme'),p=window.matchMedia('(prefers-color-scheme:dark)').matches;if(s==='dark'||(s===null&&p))document.documentElement.setAttribute('data-theme','dark')}()</script>
</head>
<body class={bodyClass}>

  <!-- Cursor -->
  <div class="cursor" id="cursor"></div>
  <!-- Page transition overlay -->
  <div class="page-transition" id="page-transition"></div>

  <!-- Nav -->
  <nav class={navClass}>
    <a href="/" class="nav-logo" aria-label="Adam Barnes"><img src="/assets/logo.svg" alt="Adam Barnes" class="nav-logo-img" /></a>
    <div class="nav-links">
      {navLinks.map((l) => (
        <a href={l.href} class={active === l.key ? 'active' : undefined}>{l.label}</a>
      ))}
    </div>
    <button class="nav-theme-btn" id="nav-theme-btn" title="Switch to dark mode" aria-label="Switch to dark mode">
      <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="19.78" y1="4.22" x2="17.66" y2="6.34"/><line x1="6.34" y1="17.66" x2="4.22" y2="19.78"/></svg>
      <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Full-screen menu -->
  <div class="menu-overlay" id="menu-overlay" role="dialog" aria-modal="true" aria-label="Navigation">
    <nav class="menu-nav">
      {menuLinks.map((l) => (
        <a href={l.href} data-page={l.page}><span>{l.label}</span></a>
      ))}
      <label class="theme-switch" for="theme-toggle" title="Toggle dark / light mode">
        <input type="checkbox" id="theme-toggle" class="theme-switch__input" aria-label="Toggle dark mode" />
        <span class="theme-switch__track">
          <span class="theme-switch__knob">
            <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="19.78" y1="4.22" x2="17.66" y2="6.34"/><line x1="6.34" y1="17.66" x2="4.22" y2="19.78"/></svg>
            <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
        </span>
      </label>
    </nav>
    <div class="menu-footer">
      <div class="menu-contact">
        <a href="mailto:hello@adambarnes.biz">hello@adambarnes.biz</a><br />
        <a href="tel:+447725970028">07725 970028</a>
      </div>
      <div class="menu-social">
        <a href="https://www.instagram.com/adammjbarnes/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://glass.photo/adam-barnes" target="_blank" rel="noopener">Glass</a>
        <a href="https://bsky.app/profile/adambarnes.biz" target="_blank" rel="noopener">Bluesky</a>
        <a href="https://500px.com/p/amjbarnesy" target="_blank" rel="noopener">500px</a>
        <a href="https://www.linkedin.com/in/adbarnes/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://adambarnesphotos.co.uk" target="_blank" rel="noopener">Photos</a>
      </div>
    </div>
  </div>

  <slot />

  <!-- Footer -->
  <footer>
    <span>© <span id="year"></span> Adam Barnes | Company: Platform Ticket LTD | No: 07755177 | <a href="/privacy.html">Privacy Policy</a></span>
    <span><a href="mailto:hello@adambarnes.biz">hello@adambarnes.biz</a> · <a href="tel:+447725970028">07725 970028</a></span>
    <div class="footer-social">
      <a href="https://www.instagram.com/adammjbarnes/" target="_blank" rel="noopener">Instagram</a>
      <a href="https://glass.photo/adam-barnes" target="_blank" rel="noopener">Glass</a>
      <a href="https://bsky.app/profile/adambarnes.biz" target="_blank" rel="noopener">Bluesky</a>
      <a href="https://500px.com/p/amjbarnesy" target="_blank" rel="noopener">500px</a>
      <a href="https://www.linkedin.com/in/adbarnes/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://adambarnesphotos.co.uk" target="_blank" rel="noopener">Photos</a>
    </div>
  </footer>

  <!-- GSAP -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <script is:inline src="/js/main.js" defer></script>
  <script is:inline>document.getElementById('year').textContent = new Date().getFullYear();</script>
  <script is:inline src="/js/cookie-consent.js"></script>
  <script is:inline defer src="/_vercel/insights/script.js"></script>
</body>
</html>
