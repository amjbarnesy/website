---
/**
 * Emits a BreadcrumbList JSON-LD block (no visible output). Consumed centrally
 * by Base.astro so every inner page inherits breadcrumbs reflecting nav
 * position. Pass at least two items (Home + current page).
 */
export interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((it, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: it.name,
    item: it.url,
  })),
};
---
{items && items.length >= 2 && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
)}
